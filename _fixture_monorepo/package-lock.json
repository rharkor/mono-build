{
  "name": "fixture-root",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "fixture-root",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/app": {
      "name": "@fixture/app",
      "version": "0.0.0",
      "dependencies": {
        "@fixture/lib": "0.0.0"
      }
    },
    "node_modules/@fixture/app": {
      "resolved": "apps/app",
      "link": true
    },
    "node_modules/@fixture/lib": {
      "resolved": "packages/lib",
      "link": true
    },
    "packages/lib": {
      "name": "@fixture/lib",
      "version": "0.0.0"
    }
  }
}
